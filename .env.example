# Required — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LLM provider for chat generation (default: gemini)
# Options: gemini | claude | openai
LLM_PROVIDER=gemini

# Required only if LLM_PROVIDER=claude
CLAUDE_API_KEY=

# Required only if LLM_PROVIDER=openai
OPENAI_API_KEY=

# Cloudflare Workers — configured via wrangler.toml, not .env
